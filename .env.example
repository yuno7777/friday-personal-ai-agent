# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=your-livekit-url
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Groq AI API key (optional, for LLM)
GROQ_API_KEY=your-groq-api-key

# Sarvam AI API key (get from https://dashboard.sarvam.ai)
SARVAM_API_KEY=your-sarvam-api-key

# OpenAI API key (optional)
OPENAI_API_KEY=your-openai-api-key

# Deepgram API key (optional)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Google Cloud credentials (only needed if STT_PROVIDER = "google")
# Path to a service-account JSON file (download from GCP Console)
GOOGLE_APPLICATION_CREDENTIALS=

# Supabase configuration for ticketing system (optional)
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

# Google AI Studio API Key (get from https://aistudio.google.com/projects)
# Required for Gemini LLM and Gemini TTS
GOOGLE_API_KEY=your-google-api-key